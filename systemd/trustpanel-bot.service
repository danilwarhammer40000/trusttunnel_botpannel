[Unit]
Description=TrustPanel Telegram Bot
After=network.target

[Service]
User=root
WorkingDirectory=/opt/trustpanel
Environment=PYTHONPATH=/opt/trustpanel
EnvironmentFile=/opt/trustpanel/.env
ExecStart=/opt/trustpanel/venv/bin/python /opt/trustpanel/bot/bot.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
